generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DB_URL")
}

enum StatusDocumento {
  pendente
  assinado
}

model Documento {
  id        String          @id @default(uuid())
  titulo    String
  descricao String?
  status    StatusDocumento @default(pendente)
  criado_em DateTime        @default(now())

  @@map("documentos")
}
